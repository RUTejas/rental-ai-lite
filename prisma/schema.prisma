generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER_ADMIN
  ADMIN
  TENANT
}

enum AccountStatus {
  ACTIVE
  PENDING
  BLOCKED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum BillType {
  ELECTRICITY
  WATER
}

enum TenantPaymentStatus {
  NOT_MARKED
  TENANT_MARKED_PAID
  TENANT_MARKED_NOT_PAID
}

enum AdminVerificationStatus {
  PENDING
  VERIFIED_PAID
  UNPAID
  OVERDUE
  WAIVED
  REJECTED_CLAIM
}

enum DocumentKind {
  ID_PROOF
  AGREEMENT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          Role
  status        AccountStatus @default(ACTIVE)
  adminId       String?
  admin         User?         @relation("AdminTenants", fields: [adminId], references: [id])
  tenants       User[]        @relation("AdminTenants")
  administeredBills UtilityBill[] @relation("AdminBills")
  tenantBills   UtilityBill[] @relation("TenantBills")
  propertiesOwned Property[] @relation("AdminProperties")
  propertiesRented Property[] @relation("TenantProperties")
  administeredRent RentRecord[] @relation("AdminRent")
  tenantRent RentRecord[] @relation("TenantRent")
  administeredDocuments RentalDocument[] @relation("AdminDocuments")
  tenantDocuments RentalDocument[] @relation("TenantDocuments")
  verifiedDocuments RentalDocument[] @relation("DocumentVerifier")
  activityLogs  ActivityLog[] @relation("ActivityActor")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([adminId])
  @@index([role])
  @@index([status])
}

model Property {
  id          String       @id @default(cuid())
  adminId     String
  tenantId    String?
  name        String
  address     String
  unit        String?
  monthlyRent Decimal      @db.Decimal(12, 2)
  status      String       @default("OCCUPIED")
  admin       User         @relation("AdminProperties", fields: [adminId], references: [id], onDelete: Cascade)
  tenant      User?        @relation("TenantProperties", fields: [tenantId], references: [id], onDelete: SetNull)
  rentRecords RentRecord[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([adminId])
  @@index([tenantId])
}

model RentRecord {
  id                      String                  @id @default(cuid())
  adminId                 String
  tenantId                String
  propertyId              String?
  billingMonth            Int
  billingYear             Int
  amount                   Decimal                 @db.Decimal(12, 2)
  dueDate                  DateTime
  tenantPaymentStatus     TenantPaymentStatus     @default(NOT_MARKED)
  tenantMarkedAt          DateTime?
  tenantNote              String?
  adminVerificationStatus AdminVerificationStatus @default(PENDING)
  adminVerifiedAt         DateTime?
  adminNote               String?
  admin                   User                    @relation("AdminRent", fields: [adminId], references: [id], onDelete: Cascade)
  tenant                  User                    @relation("TenantRent", fields: [tenantId], references: [id], onDelete: Cascade)
  property                Property?               @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([adminVerificationStatus])
}

model RentalDocument {
  id           String             @id @default(cuid())
  adminId      String
  tenantId     String
  kind         DocumentKind
  fileName     String
  mimeType     String
  fileData     String
  fileSize     Int
  status       VerificationStatus @default(PENDING)
  verifiedById String?
  verifiedAt   DateTime?
  adminNote    String?
  admin        User               @relation("AdminDocuments", fields: [adminId], references: [id], onDelete: Cascade)
  tenant       User               @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: Cascade)
  verifiedBy   User?              @relation("DocumentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([kind, status])
}

model SupportRequest {
  id          String        @id @default(cuid())
  name        String?
  email       String
  role        String?
  issueType   String
  description String
  status      SupportStatus @default(OPEN)
  adminNote   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([issueType])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorRole   Role?
  action      String
  targetId    String?
  targetType  String?
  description String
  createdAt   DateTime @default(now())
  actor       User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([actorRole])
  @@index([action])
  @@index([createdAt])
}

model UtilityBill {
  id                      String                      @id @default(cuid())
  adminId                 String
  tenantId                String
  billType                BillType
  billingMonth            Int
  billingYear             Int
  amount                   Decimal                     @db.Decimal(12, 2)
  dueDate                  DateTime
  tenantPaymentStatus     TenantPaymentStatus         @default(NOT_MARKED)
  tenantMarkedAt          DateTime?
  tenantNote              String?
  adminVerificationStatus AdminVerificationStatus     @default(PENDING)
  adminVerifiedAt         DateTime?
  adminNote               String?
  remarks                 String?
  admin                   User                        @relation("AdminBills", fields: [adminId], references: [id], onDelete: Cascade)
  tenant                  User                        @relation("TenantBills", fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([adminVerificationStatus])
  @@index([tenantPaymentStatus])
}
