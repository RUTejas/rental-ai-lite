generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER_ADMIN
  ADMIN
  TENANT
}

enum AccountStatus {
  ACTIVE
  PENDING
  BLOCKED
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum BillType {
  ELECTRICITY
  WATER
}

enum TenantPaymentStatus {
  NOT_MARKED
  TENANT_MARKED_PAID
  TENANT_MARKED_NOT_PAID
}

enum AdminVerificationStatus {
  PENDING
  VERIFIED_PAID
  UNPAID
  OVERDUE
  WAIVED
  REJECTED_CLAIM
}

enum DocumentKind {
  ID_PROOF
  AGREEMENT
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          Role
  status        AccountStatus @default(ACTIVE)
  phone         String?
  ageGroup      String?
  adminId       String?
  admin         User?         @relation("AdminTenants", fields: [adminId], references: [id])
  tenants       User[]        @relation("AdminTenants")
  administeredBills UtilityBill[] @relation("AdminBills")
  tenantBills   UtilityBill[] @relation("TenantBills")
  propertiesOwned Property[] @relation("AdminProperties")
  propertiesRented Property[] @relation("TenantProperties")
  administeredRent RentRecord[] @relation("AdminRent")
  tenantRent RentRecord[] @relation("TenantRent")
  administeredDocuments RentalDocument[] @relation("AdminDocuments")
  tenantDocuments RentalDocument[] @relation("TenantDocuments")
  verifiedDocuments RentalDocument[] @relation("DocumentVerifier")
  activityLogs  ActivityLog[] @relation("ActivityActor")
  sessions      UserSession[]
  analyticsEvents UserAnalyticsEvent[]
  notifications Notification[]
  complaintsRaised Complaint[] @relation("TenantComplaints")
  complaintsManaged Complaint[] @relation("OwnerComplaints")
  tenantReceipts RentReceipt[] @relation("TenantReceipts")
  ownerReceipts RentReceipt[] @relation("OwnerReceipts")
  verifiedReceipts RentReceipt[] @relation("ReceiptVerifier")
  noticesCreated Notice[] @relation("NoticeCreator")
  targetedNotices Notice[] @relation("NoticeOwner")
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  deletedByRole Role?
  deleteReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([adminId])
  @@index([role])
  @@index([status])
  @@index([isDeleted])
}

model Property {
  id          String       @id @default(cuid())
  adminId     String
  tenantId    String?
  name        String
  address     String
  unit        String?
  monthlyRent Decimal      @db.Decimal(12, 2)
  status      String       @default("OCCUPIED")
  admin       User         @relation("AdminProperties", fields: [adminId], references: [id], onDelete: Cascade)
  tenant      User?        @relation("TenantProperties", fields: [tenantId], references: [id], onDelete: SetNull)
  rentRecords RentRecord[]
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  deletedByRole Role?
  deleteReason String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([isDeleted])
}

model RentRecord {
  id                      String                  @id @default(cuid())
  adminId                 String
  tenantId                String
  propertyId              String?
  billingMonth            Int
  billingYear             Int
  amount                   Decimal                 @db.Decimal(12, 2)
  dueDate                  DateTime
  tenantPaymentStatus     TenantPaymentStatus     @default(NOT_MARKED)
  tenantMarkedAt          DateTime?
  tenantNote              String?
  adminVerificationStatus AdminVerificationStatus @default(PENDING)
  adminVerifiedAt         DateTime?
  adminNote               String?
  admin                   User                    @relation("AdminRent", fields: [adminId], references: [id], onDelete: Cascade)
  tenant                  User                    @relation("TenantRent", fields: [tenantId], references: [id], onDelete: Cascade)
  property                Property?               @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  receipt                 RentReceipt?
  isDeleted               Boolean                 @default(false)
  deletedAt               DateTime?
  deletedBy               String?
  deletedByRole           Role?
  deleteReason            String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([adminVerificationStatus])
  @@index([isDeleted])
}

model RentalDocument {
  id           String             @id @default(cuid())
  adminId      String
  tenantId     String
  kind         DocumentKind
  fileName     String
  mimeType     String
  fileData     String
  fileSize     Int
  status       VerificationStatus @default(PENDING)
  verifiedById String?
  verifiedAt   DateTime?
  adminNote    String?
  agreementStart DateTime?
  agreementEnd   DateTime?
  admin        User               @relation("AdminDocuments", fields: [adminId], references: [id], onDelete: Cascade)
  tenant       User               @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: Cascade)
  verifiedBy   User?              @relation("DocumentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  isDeleted    Boolean            @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deletedByRole Role?
  deleteReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([kind, status])
  @@index([isDeleted])
}

model SupportRequest {
  id          String        @id @default(cuid())
  name        String?
  email       String
  role        String?
  issueType   String
  description String
  status      SupportStatus @default(OPEN)
  adminNote   String?
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  deletedByRole Role?
  deleteReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([issueType])
  @@index([isDeleted])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorRole   Role?
  actorName   String?
  action      String
  targetId    String?
  targetType  String?
  targetName  String?
  description String
  deleteReason String?
  deletedAt   DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([actorRole])
  @@index([action])
  @@index([createdAt])
}

model MasterLoginAttempt {
  id        String   @id @default(cuid())
  emailHash String
  success   Boolean  @default(false)
  reason    String
  createdAt DateTime @default(now())

  @@index([emailHash, createdAt])
  @@index([success, createdAt])
}

model MasterAdminSetup {
  id             String   @id @default(cuid())
  setupCompleted Boolean  @default(false)
  setupKeyHash   String?
  createdAt      DateTime @default(now())
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String
  role            Role
  deviceType      String
  browser         String
  os              String
  currentPage     String   @default("/")
  loginAt         DateTime @default(now())
  lastActiveAt    DateTime @default(now())
  logoutAt        DateTime?
  sessionDuration Int      @default(0)
  isOnline        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isOnline, lastActiveAt])
  @@index([role])
}

model UserAnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String
  role       Role
  eventType  String
  page       String
  deviceType String
  browser    String
  os         String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType, createdAt])
  @@index([page, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Complaint {
  id          String   @id @default(cuid())
  tenantId    String
  ownerId     String
  title       String
  category    String
  description String
  priority    String   @default("MEDIUM")
  status      String   @default("NEW")
  imageUrl    String?
  ownerNote   String?
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  deletedByRole Role?
  deleteReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      User     @relation("TenantComplaints", fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User     @relation("OwnerComplaints", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ownerId, status])
  @@index([isDeleted])
}

model RentReceipt {
  id            String   @id @default(cuid())
  tenantId      String
  ownerId       String
  rentRecordId  String   @unique
  receiptNumber String   @unique
  amount        Decimal  @db.Decimal(12, 2)
  month         Int
  year          Int
  status        String   @default("VERIFIED_PAID")
  verifiedById  String
  verifiedAt    DateTime
  pdfUrl        String?
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  deletedByRole Role?
  deleteReason  String?
  createdAt     DateTime @default(now())
  tenant        User     @relation("TenantReceipts", fields: [tenantId], references: [id], onDelete: Cascade)
  owner         User     @relation("OwnerReceipts", fields: [ownerId], references: [id], onDelete: Cascade)
  verifiedBy    User     @relation("ReceiptVerifier", fields: [verifiedById], references: [id], onDelete: Restrict)
  rentRecord    RentRecord @relation(fields: [rentRecordId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ownerId])
  @@index([isDeleted])
}

model Notice {
  id          String   @id @default(cuid())
  createdById String
  targetRole  Role?
  ownerId     String?
  title       String
  message     String
  noticeType  String
  isImportant Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  deletedByRole Role?
  deleteReason String?
  createdAt   DateTime @default(now())
  createdBy   User     @relation("NoticeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  owner       User?    @relation("NoticeOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([ownerId])
  @@index([targetRole, createdAt])
  @@index([isDeleted])
}

model UtilityBill {
  id                      String                      @id @default(cuid())
  adminId                 String
  tenantId                String
  billType                BillType
  billingMonth            Int
  billingYear             Int
  amount                   Decimal                     @db.Decimal(12, 2)
  dueDate                  DateTime
  tenantPaymentStatus     TenantPaymentStatus         @default(NOT_MARKED)
  tenantMarkedAt          DateTime?
  tenantNote              String?
  adminVerificationStatus AdminVerificationStatus     @default(PENDING)
  adminVerifiedAt         DateTime?
  adminNote               String?
  remarks                 String?
  isDeleted               Boolean                     @default(false)
  deletedAt               DateTime?
  deletedBy               String?
  deletedByRole           Role?
  deleteReason            String?
  admin                   User                        @relation("AdminBills", fields: [adminId], references: [id], onDelete: Cascade)
  tenant                  User                        @relation("TenantBills", fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([adminId])
  @@index([tenantId])
  @@index([adminVerificationStatus])
  @@index([tenantPaymentStatus])
  @@index([isDeleted])
}
